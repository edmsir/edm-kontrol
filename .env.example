# SlipX Environment Variables Template
# Bu dosyayı .env olarak kopyalayın ve kendi anahtarlarınızı girin.

# Groq API Anahtarları (Virgülle ayırarak birden fazla girilebilir)
GROQ_API_KEYS=gsk_xxx,gsk_yyy

# Yerel Tarama Klasörü (Sadece dev_server.py için, opsiyonel)
# Örn: C:/Users/byfab/Desktop/fisler
LOCAL_SCAN_FOLDER=
